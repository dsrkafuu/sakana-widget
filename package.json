    "dev": "bun --bun run-p dev:lib dev:docs"
  },
  "dependencies": {},
  "devDependencies": {
    "@tsdown/css": "^0.21.10",
    "@types/bun": "^1.3.13",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "sass": "^1.99.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
